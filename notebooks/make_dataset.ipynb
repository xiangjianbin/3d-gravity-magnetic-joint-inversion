    "    # Add noise\n",
    "    max_g = np.max(np.abs(g_clean)); max_m = np.max(np.abs(m_clean))\n",
    "    g_noise = NOISE_GRAVITY * max_g * np.random.randn(*g_clean.shape) if max_g > 1e-15 else 0\n",
