    "# Cell 4: Implement Magnetic Forward Function (Bhattacharyya 1964)\n",
    "def prism_magnetic_numpy(obs_x, obs_y, obs_z, x1,x2,y1,y2,z1,z2,\n",
    "                           Mx,My,Mz,Fx,Fy,Fz):\n",
    "    \"\"\"Bhattacharyya (1964) prism magnetic anomaly formula.\"\"\"\n",
    "    obs_x = np.asarray(obs_x, dtype=np.float64)\n",
    "    obs_y = np.asarray(obs_y, dtype=np.float64)\n",
    "    ax,ay,az = Mx*Fx, My*Fy, Mz*Fz\n",
    "    bxy = My*Fx+Mx*Fy; bxz = Mz*Fx+Mx*Fz; byz = Mz*Fy+My*Fz\n",
    "    corners = [\n",
    "        (obs_x-x1,obs_y-y1,obs_z-z1, 1),(obs_x-x1,obs_y-y1,obs_z-z2,-1),\n",
    "        (obs_x-x1,obs_y-y2,obs_z-z1,-1),(obs_x-x1,obs_y-y2,obs_z-z2, 1),\n",
    "        (obs_x-x2,obs_y-y1,obs_z-z1,-1),(obs_x-x2,obs_y-y1,obs_z-z2, 1),\n",
    "        (obs_x-x2,obs_y-y2,obs_z-z1, 1),(obs_x-x2,obs_y-y2,obs_z-z2,-1),\n",
    "    ]\n",
    "    total = np.zeros_like(obs_x, dtype=np.float64)\n",
    "    for xi,yj,zk,mu in corners:\n",
    "        R = np.sqrt(xi**2+yj**2+zk**2); R = np.maximum(R, 1e-15)\n",
    "        t1=np.where(np.abs(xi*R)>1e-30,np.arctan2(yj*zk,xi*R),0.0)\n",
    "        t2=np.where(np.abs(yj*R)>1e-30,np.arctan2(xi*zk,yj*R),0.0)\n",
    "        t3=np.where(np.abs(zk*R)>1e-30,np.arctan2(xi*yj,zk*R),0.0)\n",
    "        l1=np.where(R+yj>1e-30,np.log(np.abs(R+yj)),0.0)\n",
    "        l2=np.where(R+zk>1e-30,np.log(np.abs(R+zk)),0.0)\n",
    "        l3=np.where(R+xi>1e-30,np.log(np.abs(R+xi)),0.0)\n",
    "        total += mu*(ax*t1+ay*t2+az*t3-bxy*l1-bxz*l2-byz*l3)\n",
    "    return total\n",
    "\n",
    "\n",
    "def compute_magnetic(suscept_model, obs_coords, obs_height=OBS_HEIGHT,\n",
    "                       dx=CELL_DX, dy=CELL_DY, dz=CELL_DZ,\n",
    "                       F_int=F_INTENSITY, F_dec=F_DECLINATION, F_inc=F_INCLINATION):\n",
    "    \"\"\"Compute magnetic anomaly. Output in nT.\"\"\"\n",
    "    nx,ny,nz = suscept_model.shape\n",
    "    ox,oy = obs_coords, obs_coords\n",
    "    OX,OY = np.meshgrid(ox,oy,indexing='ij')\n",
    "    ox_f,oy_f = OX.ravel(), OY.ravel()\n",
    "    \n",
    "    dec_rad, inc_rad = np.radians(F_dec), np.radians(F_inc)\n",
    "    Fx=np.cos(inc_rad)*np.cos(dec_rad); Fy=np.cos(inc_rad)*np.sin(dec_rad); Fz=np.sin(inc_rad)\n",
    "    Mx,My,Mz = Fx,Fy,Fz  # Induced magnetization parallel to F\n",
    "    prefactor = F_int / (4.0*np.pi)\n",
    "    \n",
    "    xb = np.arange(nx+1)*dx - nx*dx/2; yb = np.arange(ny+1)*dy - ny*dy/2; zb = np.arange(nz+1)*dz\n",
    "    nonzero = np.argwhere(suscept_model != 0)\n",
    "    \n",
    "    mag = np.zeros(len(ox_f), dtype=np.float64)\n",
    "    for idx in nonzero:\n",
    "        i,j,k = idx\n",
    "        contrib = prism_magnetic_numpy(ox_f, oy_f, obs_height,\n",
    "                                        xb[i],xb[i+1], yb[j],yb[j+1], zb[k],zb[k+1],\n",
    "                                        Mx,My,Mz,Fx,Fy,Fz)\n",
    "        mag += contrib * suscept_model[i,j,k] * prefactor\n",
    "    \n",
    "    return mag.reshape(len(ox), len(oy))\n",
    "\n",
    "print(\"Cell 4: Magnetic forward function defined.\")"
   ]
  },
