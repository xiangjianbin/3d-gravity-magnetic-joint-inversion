    "# Cell 9: Trapezoid Special Case Generator (1-5 sections)\n",
    "def gen_trapezoid(n_sections, nx=GRID_NX, ny=GRID_NY, nz=GRID_NZ, rng=None):\n",
    "    \"\"\"Trapezoidal body with n_sections vertical segments of varying width.\"\"\"\n",
    "    if rng is None: rng = np.random.RandomState()\n",
    "    rho=np.zeros((nx,ny,nz),dtype=np.float32); kap=np.zeros((nx,ny,nz),dtype=np.float32)\n",
    "    d=float(rng.choice(DENSITY_VALUES))+rng.uniform(-0.05,0.05); d=max(0.05,d)\n",
    "    k=float(rng.choice(SUSCEPTIBILITY_VALUES))+rng.uniform(-0.01,0.01); k=max(0.01,k)\n",
    "    zb=np.linspace(0,nz,n_sections+1).astype(int); zb[-1]=nz\n",
    "    bsx=rng.randint(4,nx//2); bsy=rng.randint(4,ny//2)\n",
    "    fcts=np.linspace(0.3,1.0,n_sections) if rng.random()<0.5 else np.linspace(1.0,0.3,n_sections)\n",
    "    cx=rng.randint(bsx//2,nx-bsx//2); cy=rng.randint(bsy//2,ny-bsy//2)\n",
    "    for sec in range(n_sections):\n",
    "        zs,zze=zb[sec],zb[sec+1]\n",
    "        if zze<=zs: continue\n",
    "        sx=max(2,int(bsx*fcts[sec])); sy=max(2,int(bsy*fcts[sec]))\n",
    "        x0=max(0,cx-sx//2); y0=max(0,cy-sy//2)\n",
    "        x1=min(nx,x0+sx); y1=min(ny,y0+sy)\n",
    "        rho[x0:x1,y0:y1,zs:zze]=d; kap[x0:x1,y0:y1,zs:zze]=k\n",
    "    return {'rho':rho,'kappa':kap,'sim':compute_sim(rho,kap),'type':1,'subtype':f'trapezoid_{n_sections}sec','is_trapezoid':True,'n_sections':n_sections}\n",
    "\n",
    "print(\"Cell 9: Trapezoid generator defined (1-5 sections).\")"
   ]
  },
