    "CELL_DX = 20.0    # meters\n",
    "CELL_DY = 20.0\n",
    "CELL_DZ = 20.0\n",
    "N_OBS = 81        # observation points per axis\n",
    "OBS_HEIGHT = 10.0 # observation height above surface (m)\n",
    "\n",
    "# Physical constants\n",
    "G = 6.67430e-11          # Gravitational constant (m^3 kg^-1 s^-2)\n",
    "MU_0 = 4.0 * np.pi * 1e-7  # Vacuum permeability (H/m)\n",
    "\n",
    "# Geomagnetic field (Inner Mongolia region)\n",
    "F_INTENSITY = 55000.0   # nT\n",
    "F_DECLINATION = -7.0    # degrees (west)\n",
