    "# Cell 8: Type 4/5/6 Generators — Combined Models\n",
    "def compute_sim(rho, kappa):\n",
    "    return ((rho!=0) & (kappa!=0)).astype(np.float32)\n",
    "\n",
    "def _base_model(key, nx, ny, nz, rng):\n",
    "    gens={'single_cuboid':lambda:gen_cuboid(nx,ny,nz,rng),\n",
    "          'combo_cuboid':lambda:gen_combo_cuboids(rng.randint(2,4),nx,ny,nz,rng),\n",
    "          'tilting':lambda:gen_tilting_body(nx,ny,nz,rng=rng),\n",
    "          'combo_tilting':lambda:gen_combo_tilting(rng.randint(2,4),nx,ny,nz,rng),\n",
    "          'random_walk':lambda:gen_random_walk(nx,ny,nz,rng=rng)}\n",
    "    if key=='combo_random_walk':\n",
    "        rc,rk=np.zeros((nx,ny,nz),np.float32),np.zeros((nx,ny,nz),np.float32)\n",
    "        for _ in range(rng.randint(2,4)): r,k=gen_random_walk(nx,ny,nz,rng=rng); rc=np.maximum(rc,r); rk=np.maximum(rk,k)\n",
    "        return rc,rk\n",
    "    return gens[key]() if key in gens else gen_cuboid(nx,ny,nz,rng)\n",
    "\n",
    "def gen_type4(nx,ny,nz,rng):  # Global consistency\n",
    "    keys=['single_cuboid','combo_cuboid','tilting','combo_tilting','random_walk','combo_random_walk']\n",
    "    wts=[1500,3000,1000,1000,500,500]; i=rng.choice(len(keys),p=np.array(wts,float)/sum(wts))\n",
    "    r,k=_base_model(keys[i],nx,ny,nz,rng)\n",
    "    return {'rho':r,'kappa':k,'sim':compute_sim(r,k),'type':4,'subtype':keys[i],'consistency':'global'}\n",
    "\n",
    "def gen_type5(nx,ny,nz,rng):  # Partial consistency\n",
    "    keys=['single_cuboid','combo_cuboid','tilting','combo_tilting','random_walk','combo_random_walk']\n",
    "    wts=[1500,3000,1000,1000,500,500]; i=rng.choice(len(keys),p=np.array(wts,float)/sum(wts))\n",
    "    nb=rng.randint(2,5); rc,rk=np.zeros((nx,ny,nz),np.float32),np.zeros((nx,ny,nz),np.float32)\n",
    "    for bi in range(nb):\n",
    "        r,k=_base_model(keys[i],nx,ny,nz,rng)\n",
    "        if bi>0 and rng.random()<.45:\n",
    "            if rng.random()<.5: k=np.zeros_like(k)\n",
    "            else: r=np.zeros_like(r)\n",
    "        rc=np.maximum(rc,r); rk=np.maximum(rk,k)\n",
    "    return {'rho':rc,'kappa':rk,'sim':compute_sim(rc,rk),'type':5,'subtype':keys[i],'consistency':'partial'}\n",
    "\n",
    "def gen_type6(nx,ny,nz,rng):  # Inconsistent\n",
    "    keys_r=['single_cuboid','combo_cuboid','tilting','combo_tilting','random_walk','combo_random_walk']\n",
    "    wts=[2000,4000,1000,1000,1000,2000]; i=rng.choice(len(keys_r),p=np.array(wts,float)/sum(wts))\n",
    "    keys_k=[k for k in keys_r if k!=keys_r[i]] or keys_r\n",
    "    r,_=_base_model(keys_r[i],nx,ny,nz,rng); _,k=_base_model(rng.choice(keys_k),nx,ny,nz,rng)\n",
    "    return {'rho':r,'kappa':k,'sim':compute_sim(r,k),'type':6,'subtype':keys_r[i],'consistency':'inconsistent'}\n",
    "\n",
    "print(\"Cell 8: Type 4/5/6 generators defined (combined models).\")"
