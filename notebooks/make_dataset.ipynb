    "# Cell 5: Type 1 Generator — Cuboid/Cube (with 1/2/3 body variants)\n",
    "def gen_cuboid(nx=GRID_NX, ny=GRID_NY, nz=GRID_NZ, rng=None):\n",
    "    \"\"\"Single rectangular cuboid (non-cubic aspect ratio).\"\"\"\n",
    "    if rng is None: rng = np.random.RandomState()\n",
    "    rho = np.zeros((nx,ny,nz), dtype=np.float32)\n",
    "    kap = np.zeros((nx,ny,nz), dtype=np.float32)\n",
    "    sx=rng.randint(4,nx//2+1); sy=rng.randint(4,ny//2+1); sz=rng.randint(2,nz//2+1)\n",
    "    if abs(sx-sy)<3: sx=min(nx//2,sx+rng.randint(3,8))\n",
    "    x0=rng.randint(0,max(1,nx-sx)); y0=rng.randint(0,max(1,ny-sy)); z0=rng.randint(0,max(1,nz-sz))\n",
    "    d=float(rng.choice(DENSITY_VALUES))+rng.uniform(-0.05,0.05); d=max(0.05,d)\n",
    "    k=float(rng.choice(SUSCEPTIBILITY_VALUES))+rng.uniform(-0.01,0.01); k=max(0.01,k)\n",
    "    rho[x0:x0+sx,y0:y0+sy,z0:z0+sz]=d; kap[x0:x0+sx,y0:y0+sy,z0:z0+sz]=k\n",
    "    return rho,kap\n",
    "\n",
    "def gen_cube(nx=GRID_NX, ny=GRID_NY, nz=GRID_NZ, rng=None):\n",
    "    \"\"\"Single cube (roughly equal dimensions).\"\"\"\n",
    "    if rng is None: rng = np.random.RandomState()\n",
    "    rho = np.zeros((nx,ny,nz), dtype=np.float32)\n",
    "    kap = np.zeros((nx,ny,nz), dtype=np.float32)\n",
    "    s=rng.randint(3,min(nx,ny,nz)//2+1)\n",
    "    sx=s+rng.randint(-1,2); sy=s+rng.randint(-1,2); sz=s+rng.randint(-1,2)\n",
    "    sx=max(2,min(sx,nx)); sy=max(2,min(sy,ny)); sz=max(2,min(sz,nz))\n",
    "    x0=rng.randint(0,max(1,nx-sx)); y0=rng.randint(0,max(1,ny-sy)); z0=rng.randint(0,max(1,nz-sz))\n",
    "    d=float(rng.choice(DENSITY_VALUES))+rng.uniform(-0.05,0.05); d=max(0.05,d)\n",
    "    k=float(rng.choice(SUSCEPTIBILITY_VALUES))+rng.uniform(-0.01,0.01); k=max(0.01,k)\n",
    "    rho[x0:x0+sx,y0:y0+sy,z0:z0+sz]=d; kap[x0:x0+sx,y0:y0+sy,z0:z0+sz]=k\n",
    "    return rho,kap\n",
    "\n",
    "def gen_combo_cuboids(n_bodies, nx=GRID_NX, ny=GRID_NY, nz=GRID_NZ, rng=None):\n",
    "    \"\"\"Combine n cuboids/cubes with max pooling.\"\"\"\n",
    "    if rng is None: rng = np.random.RandomState()\n",
    "    rc,rk = np.zeros((nx,ny,nz),np.float32), np.zeros((nx,ny,nz),np.float32)\n",
    "    for _ in range(n_bodies):\n",
    "        r,k = gen_cuboid(nx,ny,nz,rng) if rng.random()<0.5 else gen_cube(nx,ny,nz,rng)\n",
    "        rc = np.maximum(rc,r); rk = np.maximum(rk,k)\n",
    "    return rc,rk\n",
    "\n",
    "print(\"Cell 5: Type 1 generators defined (cuboid, cube, combo).\")"
   ]
  },
