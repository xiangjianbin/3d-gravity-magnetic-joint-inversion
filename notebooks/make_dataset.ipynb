    "# Cell 7: Type 3 Generator — Random Walk Body\n",
    "def gen_random_walk(nx=GRID_NX, ny=GRID_NY, nz=GRID_NZ,\n",
    "                      n_steps_range=(200,2000), n_walks_range=(3,12), rng=None):\n",
    "    \"\"\"Irregular body from 3D random walk with morphological dilation.\"\"\"\n",
    "    if rng is None: rng = np.random.RandomState()\n",
    "    rho = np.zeros((nx,ny,nz), dtype=np.float32)\n",
    "    kap = np.zeros((nx,ny,nz), dtype=np.float32)\n",
    "    d=float(rng.choice(DENSITY_VALUES))+rng.uniform(-0.05,0.05); d=max(0.05,d)\n",
    "    k=float(rng.choice(SUSCEPTIBILITY_VALUES))+rng.uniform(-0.01,0.01); k=max(0.01,k)\n",
    "    mx,my,mz=nx//2,ny//2,nz//2\n",
    "    mgx,mgy,mgz=nx//5,ny//5,max(1,nz//5)\n",
    "    sx=rng.randint(mgx,nx-mgx); sy=rng.randint(mgy,ny-mgy); sz=rng.randint(mgz,nz-mgz)\n",
    "    dirs=[]\n",
    "    for di in [-1,0,1]:\n",
    "        for dj in [-1,0,1]:\n",
    "            for dk in [-1,0,1]:\n",
    "                if di==0 and dj==0 and dk==0: continue\n",
    "                dirs.append((di,dj,dk))\n",
    "    dirs=np.array(dirs,int)\n",
    "    visited=set(); visited.add((sx,sy,sz))\n",
    "    nw=rng.randint(*n_walks_range); spw=max(10,rng.randint(*n_steps_range)//nw)\n",
    "    for _ in range(nw):\n",
    "        pos=np.array([sx,sy,sz],int)\n",
    "        for _ in range(spw):\n",
    "            dd=dirs[rng.randint(len(dirs))]; np=pos+dd\n",
    "            if 0<=np[0]<nx and 0<=np[1]<ny and 0<=np[2]<nz:\n",
    "                pos=np; visited.add((pos[0],pos[1],pos[2]))\n",
    "    for vx,vy,vz in visited:\n",
    "        rho[vx,vy,vz]=d; kap[vx,vy,vz]=k\n",
    "    try:\n",
    "        from scipy.ndimage import binary_dilation\n",
    "        mask=rho>0; st=np.ones((3,3,2),dtype=bool)\n",
    "        dil=binary_dilation(mask,st); nf=dil&~mask\n",
    "        if np.any(nf): rho[nf]=d*rng.uniform(.6,.95); kap[nf]=k*rng.uniform(.6,.95)\n",
    "    except ImportError: pass\n",
    "    return rho,kap\n",
    "\n",
    "print(\"Cell 7: Type 3 generator defined (random walk).\")"
   ]
  },
