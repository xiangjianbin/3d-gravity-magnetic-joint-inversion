    "# Cell 3: Implement Gravity Forward Function (Nagy 2000 Prism Formula)\n",
    "def prism_gravity_numpy(obs_x, obs_y, obs_z, x1, x2, y1, y2, z1, z2):\n",
    "    \"\"\"\n",
    "    Nagy et al. (2000) rectangular prism gravity formula.\n",
    "    Returns gravity coefficient in m/s^2 (multiply by G*rho for final value).\n",
    "    \"\"\"\n",
    "    obs_x = np.asarray(obs_x, dtype=np.float64)\n",
    "    obs_y = np.asarray(obs_y, dtype=np.float64)\n",
    "    corners = [\n",
    "        (obs_x-x1, obs_y-y1, obs_z-z1,  1), (obs_x-x1, obs_y-y1, obs_z-z2, -1),\n",
    "        (obs_x-x1, obs_y-y2, obs_z-z1, -1), (obs_x-x1, obs_y-y2, obs_z-z2,  1),\n",
    "        (obs_x-x2, obs_y-y1, obs_z-z1, -1), (obs_x-x2, obs_y-y1, obs_z-z2,  1),\n",
    "        (obs_x-x2, obs_y-y2, obs_z-z1,  1), (obs_x-x2, obs_y-y2, obs_z-z2, -1),\n",
    "    ]\n",
    "    total = np.zeros_like(obs_x, dtype=np.float64)\n",
    "    for xi, yj, zk, mu in corners:\n",
    "        R = np.sqrt(xi**2 + yj**2 + zk**2); R = np.maximum(R, 1e-15)\n",
    "        t1 = np.where(np.abs(zk*R)>1e-30, zk*np.arctan2(xi*yj, zk*R), 0.0)\n",
    "        t2 = np.where(np.abs(xi*R)>1e-30, xi*np.arctan2(yj*zk, xi*R), 0.0)\n",
    "        t3 = np.where(np.abs(yj*R)>1e-30, yj*np.arctan2(xi*zk, yj*R), 0.0)\n",
    "        total += mu * (t1 - t2 - t3)\n",
    "    return -total\n",
    "\n",
    "\n",
    "def compute_gravity(density_model, obs_coords, obs_height=OBS_HEIGHT,\n",
    "                     dx=CELL_DX, dy=CELL_DY, dz=CELL_DZ):\n",
    "    \"\"\"Compute gravity anomaly on observation grid. Output in mGal.\"\"\"\n",
    "    nx, ny, nz = density_model.shape\n",
    "    ox, oy = obs_coords, obs_coords\n",
    "    OX, OY = np.meshgrid(ox, oy, indexing='ij')\n",
    "    ox_f, oy_f = OX.ravel(), OY.ravel()\n",
    "    \n",
    "    xb = np.arange(nx+1)*dx - nx*dx/2; yb = np.arange(ny+1)*dy - ny*dy/2; zb = np.arange(nz+1)*dz\n",
    "    nonzero = np.argwhere(density_model != 0)\n",
    "    \n",
    "    grav = np.zeros(len(ox_f), dtype=np.float64)\n",
    "    rho_kgm3 = density_model * 1000.0  # g/cm^3 -> kg/m^3\n",
    "    \n",
    "    for idx in nonzero:\n",
    "        i, j, k = idx\n",
    "        contrib = prism_gravity_numpy(ox_f, oy_f, obs_height,\n",
    "                                       xb[i], xb[i+1], yb[j], yb[j+1], zb[k], zb[k+1])\n",
    "        grav += contrib * rho_kgm3[i,j,k]\n",
    "    \n",
    "    result = (-grav * G * 1e5).reshape(len(ox), len(oy))  # mGal\n",
    "    return result\n",
    "\n",
    "print(\"Cell 3: Gravity forward function defined.\")"
   ]
  },
