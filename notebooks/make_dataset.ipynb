    "# Cell 6: Type 2 Generator — Tilting Body (with 1/2/3 body variants)\n",
    "def gen_tilting_body(nx=GRID_NX, ny=GRID_NY, nz=GRID_NZ, tilt_range=(10,60), rng=None):\n",
    "    \"\"\"Single tilting body via rotation with supersampling anti-aliasing.\"\"\"\n",
    "    if rng is None: rng = np.random.RandomState()\n",
    "    rho = np.zeros((nx,ny,nz), dtype=np.float32)\n",
    "    kap = np.zeros((nx,ny,nz), dtype=np.float32)\n",
    "    lsx=rng.randint(3,nx//3); lsy=rng.randint(3,ny//2); lsz=rng.randint(2,nz//3)\n",
    "    d=float(rng.choice(DENSITY_VALUES))+rng.uniform(-0.05,0.05); d=max(0.05,d)\n",
    "    k=float(rng.choice(SUSCEPTIBILITY_VALUES))+rng.uniform(-0.01,0.01); k=max(0.01,k)\n",
    "    ang=np.radians(rng.uniform(*tilt_range)); ca,sa=np.cos(ang),np.sin(ang)\n",
    "    cx,cy,cz=lsx/2,lsy/2,lsz/2\n",
    "    ox,oy,oz=rng.uniform(.25*nx,.75*nx),rng.uniform(.25*ny,.75*ny),rng.uniform(.15*nz,.85*nz)\n",
    "    ss=3\n",
    "    lx=np.linspace(0,lsx,lsx*ss); ly=np.linspace(0,lsy,lsy*ss); lz=np.linspace(0,lsz,lsz*ss)\n",
    "    llx,lly,llz=np.meshgrid(lx,ly,lz,indexing='ij')\n",
    "    rx=llx.ravel()-cx; ry=lly.ravel()-cy; rz=llz.ravel()-cz\n",
    "    gx=rx*ca-rz*sa+ox; gy=ry+oy; gz=rx*sa+rz*ca+oz\n",
    "    v=(gx>=0)&(gx<nx)&(gy>=0)&(gy<nz)&(gz>=0)&(gz<nz)\n",
    "    gi,gxi=gx[v].astype(int),gy[v].astype(int),gz[v].astype(int)\n",
    "    w=1.0/(ss**3)\n",
    "    np.add.at(rho,(gi,gxi,gzi),d*w); np.add.at(kap,(gi,gxi,gzi),k*w)\n",
    "    return rho,kap\n",
    "\n",
    "def gen_combo_tilting(n_bodies, nx=GRID_NX, ny=GRID_NY, nz=GRID_NZ, rng=None):\n",
    "    if rng is None: rng = np.random.RandomState()\n",
    "    rc,rk = np.zeros((nx,ny,nz),np.float32), np.zeros((nx,ny,nz),np.float32)\n",
    "    for _ in range(n_bodies):\n",
    "        r,k = gen_tilting_body(nx,ny,nz,rng=rng)\n",
    "        rc=np.maximum(rc,r); rk=np.maximum(rk,k)\n",
    "    return rc,rk\n",
    "\n",
    "print(\"Cell 6: Type 2 generators defined (tilting, combo tilting).\")"
   ]
  },
